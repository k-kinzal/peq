{
    "name": "k-kinzal/peq",
    "description": "A CLI application using Symfony Console.",
    "type": "project",
    "bin": [
        "bin/console"
    ],
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.1",
        "fakerphp/faker": "^1.24",
        "phpstan/phpstan": "^2.0",
        "symfony/config": "^6.4|^7.0",
        "symfony/console": "^6.4|^7.0",
        "symfony/dependency-injection": "^6.4|^7.0",
        "symfony/validator": "^6.4|^7.0",
        "symfony/yaml": "^6.4|^7.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.0",
        "phpunit/phpunit": "^10.0|^11.0|^12.0",
        "bamarni/composer-bin-plugin": "^1.8",
        "vimeo/psalm": "^5.0|^6.0",
        "mikey179/vfsstream": "^1.6",
        "phpstan/phpstan-symfony": "^2.0",
        "phpstan/phpstan-strict-rules": "^2.0",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0",
        "dg/bypass-finals": "^1.9",
        "giorgiosironi/eris": "^1.0"
    },
    "scripts": {
        "post-install-cmd": [
            "@composer bin box require --dev humbug/box"
        ],
        "post-update-cmd": [
            "@composer bin box require --dev humbug/box"
        ],
        "format": "php-cs-fixer fix .",
        "lint:php-cs-fixer": "php-cs-fixer fix --diff --dry-run .",
        "lint:phpstan": "phpstan analyze --memory-limit=1G",
        "lint": [
            "@lint:php-cs-fixer",
            "@lint:phpstan"
        ],
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:integration": "phpunit --testsuite integration",
        "test:contract": "phpunit --testsuite contract",
        "compile": "box compile"
    },
    "extra": {
        "bamarni-bin": {
            "bin-links": true,
            "target-directory": "vendor-bin",
            "forward-command": true
        }
    },
    "config": {
        "allow-plugins": {
            "bamarni/composer-bin-plugin": true
        }
    }
}
